# REQUIRED: Your Discord channel webhook URL
# Create one in: Channel Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1495076355186884799/y3slW79TSuQ8_VOxxkt_6vPxqo6Laplnd3NwqEFRV1G8ktf29fTMiSu46hVtlHwqHcPN

# OPTIONAL: RustMagic WebSocket URL (default shown)
RUSTMAGIC_WS_URL=wss://rustmagic.com

# OPTIONAL: How often to poll the HTTP fallback API (ms). Default: 30000
CHECK_INTERVAL_MS=30000

# OPTIONAL: Set to "true" to log every raw WebSocket event (useful for debugging)
DEBUG_EVENTS=false
